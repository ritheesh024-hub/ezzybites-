
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // UTILITY FUNCTIONS
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function getAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == "sunnyritheesh@gmail.com"
      );
    }
    function isKitchen() {
      return isAdmin() && (request.auth.token.email == "sunnyritheesh@gmail.com" || getAdminData().role == 'kitchen');
    }
    function isCashier() {
      return isAdmin() && (request.auth.token.email == "sunnyritheesh@gmail.com" || getAdminData().role == 'cashier');
    }
    function isMasterAdmin() {
      return isAdmin() && (request.auth.token.email == "sunnyritheesh@gmail.com" || getAdminData().role == 'admin');
    }

    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isMasterAdmin() || (isAuthenticated() && request.auth.token.email == "sunnyritheesh@gmail.com");
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isMasterAdmin() 
                    // Kitchen can only move to preparing
                    || (isKitchen() && request.resource.data.status == 'preparing' && resource.data.status == 'accepted')
                    // Cashier can move to out_for_delivery or delivered
                    || (isCashier() && request.resource.data.status in ['out_for_delivery', 'delivered'] && resource.data.status in ['preparing', 'out_for_delivery'])
                    // User can only cancel if still pending or accepted
                    || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'Cancelled' && resource.data.status in ['pending', 'accepted']);
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /user_notifications/{userId}/items/{id} {
      allow read: if isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /favorites/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /login_events/{id} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /activity_logs/{id} {
      allow create: if isAdmin();
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
